{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the catalog.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product." },
        "description": { "type": "string", "description": "A detailed description." },
        "price": { "type": "number", "description": "The price in BRL." },
        "image": { "type": "string", "description": "URL of the product image." },
        "category": { "type": "string", "description": "The category ID." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When it was created." }
      },
      "required": ["name", "price", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the category." }
      },
      "required": ["name"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "The user's email." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role." }
      },
      "required": ["email", "role"]
    },
    "StoreSettings": {
      "title": "StoreSettings",
      "description": "Global settings for the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the store." },
        "address": { "type": "string", "description": "The physical address." },
        "status": { "type": "string", "description": "Current status (e.g., Aberto/Fechado)." },
        "openingHours": { "type": "string", "description": "Opening hours string." },
        "logo": { "type": "string", "description": "URL of the logo image." },
        "banner": { "type": "string", "description": "URL of the banner image." },
        "whatsapp": { "type": "string", "description": "WhatsApp number for contact." }
      },
      "required": ["name", "logo", "banner", "whatsapp"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "A customer testimonial.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the customer." },
        "avatar": { "type": "string", "description": "URL of the customer's avatar image." },
        "rating": { "type": "number", "description": "The rating given by the customer (1-5)." },
        "comment": { "type": "string", "description": "The customer's feedback comment." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When it was created." }
      },
      "required": ["name", "rating", "comment"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of categories."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users."
    },
    "/settings/{settingId}": {
      "schema": "StoreSettings",
      "description": "Global store settings."
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Collection of customer testimonials."
    }
  }
}
